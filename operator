(logical opertor)
&&=one condition false result false
||(or)=one condition true result true
!(not)=giving opposite result
class Oper
{
public static void main(String args[])
{
int a=100;
int b=99;
int c=89;
boolean d=a>b&&b>a;
System.out.println("d="+d);
boolean d1=a>b||c>b;
System.out.println(d1);
boolean d2=!(a>b||c>b);
System.out.println(d2);
}
}
